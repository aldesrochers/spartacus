#ifndef __Spartacus_Version_hxx__
#define __Spartacus_Version_hxx__

// Compiler
#define Spartacus_COMPILER_ID       "@CMAKE_CXX_COMPILER_ID@"
#define Spartacus_COMPILER_VERSION  "@CMAKE_CXX_COMPILER_VERSION@"

// Version
#define Spartacus_VERSION_MAJOR     "@Spartacus_VERSION_MAJOR@"
#define Spartacus_VERSION_MINOR     "@Spartacus_VERSION_MINOR@"
#define Spartacus_VERSION_PATCH     "@Spartacus_VERSION_PATCH@"
#define Spartacus_VERSION_STRING    "@Spartacus_VERSION_MAJOR@.@Spartacus_VERSION_MINOR@.@Spartacus_VERSION_PATCH@"

#endif  // __Spartacus_Version_hxx__
