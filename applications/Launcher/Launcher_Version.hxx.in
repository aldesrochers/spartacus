#ifndef __Launcher_Version_hxx__
#define __Launcher_Version_hxx__

// Compiler
#define Launcher_COMPILER_ID        "@CMAKE_CXX_COMPILER_ID@"
#define Launcher_COMPILER_VERSION   "@CMAKE_CXX_COMPILER_VERSION@"

// Version
#define Launcher_VERSION_MAJOR      "@Launcher_VERSION_MAJOR@"
#define Launcher_VERSION_MINOR      "@Launcher_VERSION_MINOR@"
#define Launcher_VERSION_PATCH      "@Launcher_VERSION_PATCH@"
#define Launcher_VERSION_STRING     "@Launcher_VERSION_MAJOR@.@Launcher_VERSION_MINOR@.@Launcher_VERSION_PATCH@"

#endif  // __Launcher_Version_hxx__
